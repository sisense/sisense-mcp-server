# Server port (default: 3001)
# PORT=3001

# Set to "true" or "1" to use the minimal "Hello MCP Server!" app and stubbed buildChart (no chart
# engine, no Sisense). Use this to debug "MCP Client cannot open the app" by isolating app loading
# and tool-result delivery from chart/artifact logic.
# SIMPLE_APP_DEBUG=false

# Set to "true" (default) for MCP App mode: interactive chart in app, no image. Set to "false" for
# normal tool mode: chart image generated and imageUrl in response (for clients without MCP App support).
# MCP_APP_BUILD_CHART_ENABLED=true

# Sisense connection (used when URL params are not set). Also used for CSP when serving the
# analytics View (MCP Apps) so the View iframe can connect to Sisense. When users connect
# with ?sisenseUrl=... in the URL, that value is used for CSP instead.
# SISENSE_URL=https://your-instance.sisense.com
# SISENSE_TOKEN=your-api-token

# Optional: S3 bucket for chart screenshots (multi-instance deployments).
# SCREENSHOTS_BUCKET=

# Optional: AWS region when using S3 for screenshots.
# AWS_REGION=us-east-1
