# Sisense Configuration
SISENSE_URL=https://your-instance.sisense.com
SISENSE_TOKEN=your-api-token-here

# MCP Server Configuration
# Base URL where this MCP server is accessible (required for serving chart screenshots)
# For local development: http://localhost:3000
# For production/remote: use ngrok or your public domain
BASE_URL=http://localhost:3000