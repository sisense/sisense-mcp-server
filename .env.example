# Server port (default: 3001)
# PORT=3001

# Sisense connection (used when URL params are not set).
# SISENSE_URL=https://your-instance.sisense.com
# SISENSE_TOKEN=your-api-token

# Optional: S3 bucket for chart screenshots (multi-instance deployments).
# SCREENSHOTS_BUCKET=

# Optional: AWS region when using S3 for screenshots.
# AWS_REGION=us-east-1

# Set to "true" to enable the query builder tool (default: false).
# URL query param override: toolBuildQueryEnabled=true|false
# TOOL_BUILD_QUERY_ENABLED=false

# Set to "false" to disable NLG narrative/insights in the chart builder (default: true).
# URL query param override: toolBuildChartNarrativeEnabled=true|false
# TOOL_BUILD_CHART_NARRATIVE_ENABLED=true

# Set to "true" (default) for MCP App mode: interactive chart in app, no image. Set to "false" for
# normal tool mode: chart image generated and imageUrl in response (for clients without MCP App support).
# This only affects how the tool is registered (resource vs normal tool); it does not enable/disable
# the chart builder.
# URL query param override: mcpAppEnabled=true|false
# MCP_APP_ENABLED=true